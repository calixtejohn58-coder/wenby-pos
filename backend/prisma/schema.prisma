model Sale {

  id             String      @id @default(cuid())

  total          Float

  customerName   String?

  customerPhone  String?

  createdAt      DateTime    @default(now())

  cashierId      String?

  cashier        User?       @relation(fields: [cashierId], references: [id])

  businessId     String?

  business       Business?   @relation(fields: [businessId], references: [id])

  items          SaleItem[]
}